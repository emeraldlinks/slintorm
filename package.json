{
  "name": "slintorm",
  "version": "1.6.0",
  "description": "Minimal fully typed orm for typescript",
  "license": "MIT",
  "author": "Joseph Christopher",
  "type": "module",
  "homepage": "https://slintorm.vercel.app",
  "bugs": {
    "url": "https://github.com/emeraldlinks/slintorm/issues"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "browser": "./dist/src/browser.js",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emeraldlinks/slintorm.git"
  },
  "bin": {
    "slintorm": "./dist/src/bin/cli.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "prepare": "npm run build",
    "test": "tsx src/example.ts",
    "test:suite": "node --import tsx/esm src/slintorm.test.ts",
    "test:types": "tsc --noEmit src/types.test.ts",
    "cli": "tsx src/bin/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.5",
    "@types/sqlite3": "^3.1.11",
    "mongodb": "^7.4.0",
    "mysql2": "^3.22.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "uvu": "^0.5.6",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {}
}
